<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hvktmm.MainController">
    
    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label styleClass="header-label" text="HỆ THỐNG BẢO MẬT FILE &amp; THƯ MỤC" />
        <Label styleClass="sub-label" text="Driver: /dev/cipher_dev | Lõi C Backend" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="450.0">
        <Button onAction="#handleSelectFiles" styleClass="btn, btn-select" text="📂 Chọn File(s)" />
        <Button onAction="#handleSelectFolder" styleClass="btn, btn-select" style="-fx-background-color: #8e44ad;" text="📁 Chọn Thư Mục" />
    </HBox>

    <ListView fx:id="listViewFiles" prefHeight="220.0" prefWidth="450.0" styleClass="list-view" />

    <HBox alignment="CENTER" spacing="20.0">
        <Button onAction="#handleEncrypt" styleClass="btn, btn-encrypt" text="🔒 Mã Hóa" />
        <Button onAction="#handleDecrypt" styleClass="btn, btn-decrypt" text="🔓 Giải Mã" />
        <Button onAction="#handleEdit" styleClass="btn, btn-edit" text="✏️ Chỉnh Sửa (Nano)" />
    </HBox>
    
    <Label fx:id="statusLabel" styleClass="status-label" text="Hệ thống sẵn sàng..." textFill="#7f8c8d" />
    
</VBox>
